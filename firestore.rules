rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Per-user data - only the owner can read/write.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Exam catalog - readable by signed-in users; writes happen via Admin SDK.
    match /content/exams/items/{examId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    // Uploaded PYQ volume metadata. Actual PDFs live in Cloud Storage.
    match /content/pyqVolumes/items/{volumeId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    // Block all other paths by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

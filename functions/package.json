{
  "name": "sitheer-functions",
  "description": "Secure mentor proxy - keeps Gemini/OpenAI keys off the client",
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "seed:content": "node scripts/import-content.js ../content/seed",
    "seed:questions": "node scripts/import-questions.js ../assets/questions",
    "upload:pyq": "node scripts/upload-pyq-volumes.js"
  },
  "engines": {
    "node": "20"
  },
  "main": "index.js",
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0"
  }
}

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Authenticated students can read uploaded prep materials.
    match /content/{examId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
